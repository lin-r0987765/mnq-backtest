// https://mozilla.org/MPL/2.0/
// ICT ORB v33 AutoTrade Bridge for TradingView webhook alerts
//@version=6
strategy("ICT ORB v33 AutoTrade Bridge", overlay=true,
     initial_capital=100000,
     default_qty_type=strategy.fixed,
     default_qty_value=10,
     commission_type=strategy.commission.percent,
     commission_value=0.05,
     pyramiding=0,
     process_orders_on_close=true)

grpBase = "ORB"
orbBars = input.int(4, "Opening Range Bars", minval=2, maxval=8, group=grpBase)
profitRatio = input.float(3.5, "Profit Ratio", minval=2.0, maxval=6.0, step=0.1, group=grpBase)
breakoutConfirmPct = input.float(0.0003, "Breakout Confirm Pct", minval=0.0, maxval=0.01, step=0.0001, group=grpBase)
entryDelayBars = input.int(0, "Entry Delay Bars", minval=0, maxval=5, group=grpBase)
minRangePct = input.float(0.001, "Min ORB Range Pct", minval=0.0001, maxval=0.01, step=0.0001, group=grpBase)
closeBeforeMin = input.int(10, "Close Before Session End (min)", minval=1, maxval=60, group=grpBase)

grpTrend = "Trend Filter"
htfFilter = input.bool(true, "Enable 1h Bias Filter", group=grpTrend)
htfMode = input.string("slope", "1h Mode", options=["slope", "ema_cross"], group=grpTrend)
htfEmaFast = input.int(20, "1h EMA Fast", minval=10, maxval=30, group=grpTrend)
htfEmaSlow = input.int(30, "1h EMA Slow", minval=20, maxval=60, group=grpTrend)

grpRegime = "Regime Filter"
skipShortAfterUpDays = input.int(2, "Skip Short After Up Days", minval=0, maxval=5, group=grpRegime)
skipLongAfterUpDays = input.int(3, "Skip Long After Up Days", minval=0, maxval=5, group=grpRegime)

grpRisk = "Risk"
trailingStop = input.bool(true, "Enable Trailing Stop", group=grpRisk)
trailingPct = input.float(0.013, "Trailing Pct", minval=0.001, maxval=0.05, step=0.001, group=grpRisk)

grpWebhook = "Webhook"
webhookSecret = input.string("change-this-shared-secret", "Shared Secret", group=grpWebhook)
webhookStrategy = input.string("ORB", "Strategy Tag", group=grpWebhook)
webhookQty = input.float(10, "Webhook Qty (Fallback / Override)", minval=0.1, step=0.1, group=grpWebhook)
webhookSymbol = input.string("QQQ", "Webhook Symbol", group=grpWebhook)

rthSession = input.session("0930-1600", "Regular Session", group="Session")
tfOk = timeframe.isintraday and timeframe.multiplier == 5
inRTH = not na(time(timeframe.period, rthSession))
newSession = inRTH and (not nz(inRTH[1]) or ta.change(time("D")) != 0)

minutesNow = hour(time, "America/New_York") * 60 + minute(time, "America/New_York")
forceClose = inRTH and minutesNow >= (16 * 60 - closeBeforeMin)

emaFast1h = request.security(syminfo.tickerid, "60", ta.ema(close, htfEmaFast), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
emaSlow1h = request.security(syminfo.tickerid, "60", ta.ema(close, htfEmaSlow), gaps=barmerge.gaps_off, lookahead=barmerge.lookahead_off)
htfBias = htfMode == "slope" ? (emaFast1h > emaFast1h[1] ? 1 : emaFast1h < emaFast1h[1] ? -1 : 0) : (emaFast1h > emaSlow1h ? 1 : emaFast1h < emaSlow1h ? -1 : 0)

var float sessionOpen = na
var float sessionClose = na
var int upDayStreak = 0
var int barsFromOpen = 0
var float orbHigh = na
var float orbLow = na
var float bestPriceLong = na
var float bestPriceShort = na

if newSession
    if not na(sessionOpen) and not na(sessionClose)
        upDayStreak := sessionClose > sessionOpen ? upDayStreak + 1 : 0
    sessionOpen := open
    sessionClose := close
    barsFromOpen := 1
    orbHigh := na
    orbLow := na
else if inRTH
    sessionClose := close
    barsFromOpen += 1

if inRTH and barsFromOpen <= orbBars
    orbHigh := na(orbHigh) ? high : math.max(orbHigh, high)
    orbLow := na(orbLow) ? low : math.min(orbLow, low)

allowShortToday = not (skipShortAfterUpDays > 0 and upDayStreak >= skipShortAfterUpDays)
allowLongToday = not (skipLongAfterUpDays > 0 and upDayStreak >= skipLongAfterUpDays)

rangeWidth = orbHigh - orbLow
midPrice = (orbHigh + orbLow) / 2.0
rangeValid = tfOk and inRTH and barsFromOpen > (orbBars + entryDelayBars) and not na(rangeWidth) and rangeWidth > 0 and not na(midPrice) and midPrice > 0 and (rangeWidth / midPrice) >= minRangePct

longEntryLevel = orbHigh * (1.0 + breakoutConfirmPct)
shortEntryLevel = orbLow * (1.0 - breakoutConfirmPct)
tpLong = orbHigh + profitRatio * rangeWidth
tpShort = orbLow - profitRatio * rangeWidth

tradeWindow = tfOk and inRTH and barsFromOpen > (orbBars + entryDelayBars) and not forceClose
noPosition = strategy.position_size == 0

longEntry = noPosition and tradeWindow and rangeValid and allowLongToday and close > longEntryLevel and (not htfFilter or htfBias != -1)
shortEntry = noPosition and tradeWindow and rangeValid and allowShortToday and close < shortEntryLevel and (not htfFilter or htfBias != 1)

if longEntry
    strategy.entry("ORB Long", strategy.long)
    bestPriceLong := close
    bestPriceShort := na

if shortEntry
    strategy.entry("ORB Short", strategy.short)
    bestPriceShort := close
    bestPriceLong := na

if strategy.position_size > 0
    bestPriceLong := na(bestPriceLong) ? close : math.max(bestPriceLong, close)
else if strategy.position_size <= 0
    bestPriceLong := na

if strategy.position_size < 0
    bestPriceShort := na(bestPriceShort) ? close : math.min(bestPriceShort, close)
else if strategy.position_size >= 0
    bestPriceShort := na

longExit = false
shortExit = false
longExitReason = ""
shortExitReason = ""

if strategy.position_size > 0
    trailLong = trailingStop and not na(bestPriceLong) ? bestPriceLong * (1.0 - trailingPct) : orbLow
    effectiveLongStop = math.max(nz(orbLow, trailLong), nz(trailLong, orbLow))
    if close <= effectiveLongStop
        longExit := true
        longExitReason := "SL/Trail"
    else if close >= tpLong
        longExit := true
        longExitReason := "TP"
    else if forceClose
        longExit := true
        longExitReason := "EOD"

if strategy.position_size < 0
    trailShort = trailingStop and not na(bestPriceShort) ? bestPriceShort * (1.0 + trailingPct) : orbHigh
    effectiveShortStop = math.min(nz(orbHigh, trailShort), nz(trailShort, orbHigh))
    if close >= effectiveShortStop
        shortExit := true
        shortExitReason := "SL/Trail"
    else if close <= tpShort
        shortExit := true
        shortExitReason := "TP"
    else if forceClose
        shortExit := true
        shortExitReason := "EOD"

if longExit
    strategy.close("ORB Long", comment=longExitReason)

if shortExit
    strategy.close("ORB Short", comment=shortExitReason)

make_payload(action, side, orderId, commentText, stopLoss, takeProfit) =>
    "{" +
    "\"secret\":\"" + webhookSecret + "\"," +
    "\"strategy\":\"" + webhookStrategy + "\"," +
    "\"symbol\":\"" + webhookSymbol + "\"," +
    "\"timeframe\":\"" + timeframe.period + "\"," +
    "\"action\":\"" + action + "\"," +
    "\"side\":\"" + side + "\"," +
    "\"qty\":" + str.tostring(webhookQty) + "," +
    "\"price\":" + str.tostring(close, format.mintick) + "," +
    "\"stop_loss\":" + str.tostring(stopLoss, format.mintick) + "," +
    "\"take_profit\":" + str.tostring(takeProfit, format.mintick) + "," +
    "\"order_id\":\"" + orderId + "\"," +
    "\"comment\":\"" + commentText + "\"," +
    "\"event_time\":\"" + str.tostring(time_close) + "\"" +
    "}"

if longEntry
    alert(make_payload("entry", "buy", "ORB_LONG", "ORB Long", orbLow, tpLong), alert.freq_once_per_bar_close)

if shortEntry
    alert(make_payload("entry", "sell", "ORB_SHORT", "ORB Short", orbHigh, tpShort), alert.freq_once_per_bar_close)

if longExit
    alert(make_payload("exit", "buy", "ORB_LONG_EXIT", "ORB Exit " + longExitReason, orbLow, tpLong), alert.freq_once_per_bar_close)

if shortExit
    alert(make_payload("exit", "sell", "ORB_SHORT_EXIT", "ORB Exit " + shortExitReason, orbHigh, tpShort), alert.freq_once_per_bar_close)

plot(rangeValid ? orbHigh : na, "ORB High", color=color.new(color.green, 0), linewidth=2, style=plot.style_stepline)
plot(rangeValid ? orbLow : na, "ORB Low", color=color.new(color.red, 0), linewidth=2, style=plot.style_stepline)
plot(rangeValid ? longEntryLevel : na, "Long Entry", color=color.new(color.green, 60), style=plot.style_stepline)
plot(rangeValid ? shortEntryLevel : na, "Short Entry", color=color.new(color.red, 60), style=plot.style_stepline)
plot(rangeValid ? tpLong : na, "TP Long", color=color.new(color.lime, 60))
plot(rangeValid ? tpShort : na, "TP Short", color=color.new(color.fuchsia, 60))
plotshape(longEntry, title="Long Signal", location=location.belowbar, style=shape.triangleup, color=color.green, size=size.tiny)
plotshape(shortEntry, title="Short Signal", location=location.abovebar, style=shape.triangledown, color=color.red, size=size.tiny)
